// Funciones de Usuarios
const loadUsers = async () => {
  try {
    if (mongoose.connection.readyState !== 1) {
      // Fallback a archivo si MongoDB no está conectado
      return loadUsersFromFile();
    }
    const users = await User.find().lean();
    return users.map(u => ({ ...u, _id: undefined, __v: undefined }));
  } catch (error) {
    console.error('Error cargando usuarios de MongoDB:', error);
    return loadUsersFromFile();
  }
};

const saveUsers = async (users) => {
  try {
    if (mongoose.connection.readyState !== 1) {
      return saveUsersToFile(users);
    }
    // MongoDB maneja los usuarios individualmente, no necesitamos reemplazar todo
    return true;
  } catch (error) {
    console.error('Error guardando usuarios en MongoDB:', error);
    return saveUsersToFile(users);
  }
};

// Funciones de Mensajes
